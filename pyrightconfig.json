{
  "include": [
    "backend/src",
    "backend/tests"
  ],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "node_modules",
    ".ruff_cache",
    ".hypothesis"
  ],
  "extraPaths": [
    "backend/src"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.13",
  "pythonPlatform": "Windows",
  "typeCheckingMode": "standard",
  "reportMissingTypeStubs": false,
  "reportUnusedImport": "warning",
  "reportUnusedVariable": "warning",
  "reportDuplicateImport": "warning"
}
