# Novel AI configuration
# Copy this file to .env and set your own values.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Runtime environment (development/production)
# In production: enables https_only cookies, session secret fail-closed, etc.
ENV=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

NOVEL_LIBRARY_DIR=storage/novel_library

# Storage backend: "filesystem" (default) or "s3"
# When using S3, NOVEL_LIBRARY_DIR becomes the local base reference path;
# actual I/O routes through the S3 bucket.
#STORAGE_BACKEND=filesystem
#S3_BUCKET=your-bucket-name
#S3_REGION=us-east-1
#S3_KEY_PREFIX=
#S3_ENDPOINT=https://s3.amazonaws.com
# S3/R2 credentials. Required for R2 and other S3-compatible targets without IAM.
# Leave unset when using AWS S3 with IAM role credentials.
#S3_ACCESS_KEY_ID=your-access-key-id
#S3_SECRET_ACCESS_KEY=your-secret-access-key
#
# Cloudflare R2 example:
#STORAGE_BACKEND=s3
#S3_BUCKET=dokushodo
#S3_REGION=auto
#S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#S3_ACCESS_KEY_ID=fc073368ad3dcab67c65eb3371876e40
#S3_SECRET_ACCESS_KEY=0d7f5a6826e7d35a60965b9e821b1755bfe25c2e5b404d8a0187caa03e6c7851
# S3 storage soft limit in GB (default 9.5 — under R2 free tier 10 GB).
# Admin health reports storage usage; warning at 90%, critical at 95%.
#S3_STORAGE_LIMIT_GB=9.5

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------

WEB_HOST=127.0.0.1
WEB_PORT=8000

# CORS origins: empty list for same-origin behind reverse proxy (recommended).
# For cross-origin deployments, set to a JSON array:
#   WEB_CORS_ORIGINS=["https://frontend.example.com"]
#WEB_CORS_ORIGINS=[]

# Rate limiter backend: "memory" (default, single-instance) or "redis" (multi-instance).
# For production/multi-instance deployments, set WEB_RATE_LIMITER_BACKEND=redis and ensure REDIS_URL is configured.
WEB_RATE_LIMITER_BACKEND=memory

# ---------------------------------------------------------------------------
# Translation providers
# ---------------------------------------------------------------------------

PROVIDER_DEFAULT=gemini
#PROVIDER_GEMINI_API_KEY=your-google-ai-studio-api-key
# Required before storing admin-managed provider API keys in the database.
# Generate a strong random value and keep it secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#PROVIDER_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-local-secret
PROVIDER_GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
#PROVIDER_GEMINI_MODEL_FALLBACKS=[]

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# Required when running with the db extra or in production.
# Development: use local Docker Compose postgres service.
# Format: postgresql+psycopg://user:password@host:port/dbname
#DATABASE_URL=postgresql+psycopg://***@localhost:5432/novelai

# ---------------------------------------------------------------------------
# Redis (for RQ background workers)
# ---------------------------------------------------------------------------

#REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Session / Auth
# ---------------------------------------------------------------------------

# Secret key for signing HTTP-only session cookies.
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The app refuses to start in production if this is left at the default value.
#SESSION_SECRET_KEY=changeme-generate-a-real-secret-in-production

# Bootstrap secret for the owner to log in before Google OAuth.
# Set to a strong random value; never commit the real value.
#OWNER_BOOTSTRAP_SECRET=your-owner-bootstrap-secret

# Session cookie max age in seconds (default: 8 hours).
#SESSION_MAX_AGE=28800

# ---------------------------------------------------------------------------
# Google OAuth (public user login)
# ---------------------------------------------------------------------------

# Google OAuth is disabled unless all three values are set.
# Configure in Google Cloud Console:
#   1. Create OAuth 2.0 Client ID (Web application type)
#   2. Add authorized redirect URI:
#      - Development: http://127.0.0.1:8000/api/auth/google/callback
#      - Production:  https://yourdomain.com/api/auth/google/callback
#
#GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
#GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
#GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Frontend base URL for post-OAuth redirect.
# Development: http://127.0.0.1:3000
# Production:  https://yourdomain.com
#PUBLIC_FRONTEND_URL=http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Auth email delivery (password reset / email verification)
# ---------------------------------------------------------------------------

# Safe default: no email is sent. Set to "smtp" only after SMTP vars are ready.
#AUTH_EMAIL_DELIVERY_MODE=noop

# Reset/verification links use PUBLIC_FRONTEND_URL plus these frontend paths.
# Token-bearing reset/verification URLs are bearer credentials; never log them.
#AUTH_PASSWORD_RESET_PATH=/password/reset
#AUTH_EMAIL_VERIFICATION_PATH=/email/verify

# SMTP is optional and uses Python stdlib only. Do not commit real credentials.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USERNAME=your-smtp-username
#SMTP_PASSWORD=your-smtp-password
#SMTP_FROM_EMAIL=noreply@yourdomain.com
#SMTP_FROM_NAME=Dokushodo
#SMTP_STARTTLS=true
#SMTP_USE_SSL=false
#SMTP_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Docker Compose deployment (see deploy/compose.yml)
# ---------------------------------------------------------------------------

#POSTGRES_USER=novelai
#POSTGRES_PASSWORD=***
#POSTGRES_DB=novelai
#POSTGRES_HOST_PORT=5432
#PUBLIC_HTTP_PORT=80
#PUBLIC_HTTPS_PORT=443
#SITE_DOMAIN=yourdomain.com
