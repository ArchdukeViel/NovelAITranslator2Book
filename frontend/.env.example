# Frontend environment configuration
#
# These variables are baked into the Next.js build at compile time.
# In production behind Caddy, same-origin defaults work correctly.

# ---------------------------------------------------------------------------
# API base URLs
# ---------------------------------------------------------------------------

# Admin API client base URL (used by frontend/lib/api.ts).
# Paths like /admin/novels are prefixed with this value.
# Default: /api (same-origin behind Caddy)
NEXT_PUBLIC_API_BASE_URL=/api

# Public API client base URL (used by frontend/lib/public-api.ts).
# Paths like /api/auth/csrf already include the /api prefix, so this
# defaults to empty string (same-origin).
# Default: "" (empty string)
#NEXT_PUBLIC_API_URL=

# Backend URL for Next.js server-side rewrites (build-time only).
# Used by next.config.mjs to proxy /api/* to the backend during development.
# In production behind Caddy, the reverse proxy handles this directly.
# Default: http://127.0.0.1:8000
BACKEND_API_URL=http://127.0.0.1:8000
