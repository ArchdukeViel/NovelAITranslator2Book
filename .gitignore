# -----------------------------------------------------------------------------
# NovelAITranslator2Book - .gitignore
# -----------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*.pyo
*$py.class
*.so
.python-version

# Packaging / build
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.next-dev/
frontend/out/
frontend/.env.local
frontend/.env.*.local
.cache/
.coverage
.coverage.*
htmlcov/

# Test / temp artifacts
tests_tmp/
pytest-cache-files-*/
tmp/
.temp/
.tmp/
backend/tests/.tmp/
backend/tests/.cache/
backend/tests/.pytest_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
.directory
.Trash-*
__MACOSX/

# Local env / secrets
.env
.env.*
!.env.example

# Runtime data
novel_library/
storage/novel_library/
storage/novel_library/preferences.json
storage/novel_library/translation_cache.json
storage/novel_library/usage.json
storage/novel_library/activity_log/*.json
storage/output/
storage/input/
storage/logs/
storage_backups/
output/
input/
logs/
*.log
backups/
storage/backups/
*.bak
*.backup
*.orig
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Legacy path (pre-consolidation)
data/

# Session exports
SESSION_EXPORT_*.json

# Agent working directory (Hermes plans/scratch live here; promote keepers to docs/)
.hermes/
.agents/

# Documentation (tracking)
# Note: All .md files are tracked in git for documentation history
# docs/history/ contains archived phase completion and review docs
# These are intentionally committed for project memory and version history

# Node dependencies
node_modules/
frontend/node_modules/
