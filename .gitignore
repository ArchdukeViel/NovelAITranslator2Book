# -----------------------------------------------------------------------------
# NovelAITranslator2Book - .gitignore
# -----------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.python-version

# Packaging / build
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
.coverage.*
htmlcov/

# Test / temp artifacts
tests_tmp/
pytest-cache-files-*/
tmp/
.temp/
.tmp/
tests/.tmp/
tests/.cache/
tests/.pytest_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
.directory
.Trash-*
__MACOSX/

# Local env / secrets
.env
.env.*
!.env.example

# Runtime data
novel_library/
output/
input/
logs/
persistent_data.json
gptwntranslator.log

# Legacy path (pre-consolidation)
data/

# Local config
config/config.yaml

# Generated dependency artifacts
requirements.in

# Misc logs
*.log

# Session exports
SESSION_EXPORT_*.json

# Documentation (tracking)
# Note: All .md files are tracked in git for documentation history
# docs/history/ contains archived phase completion and review docs
# These are intentionally committed for project memory and version history
