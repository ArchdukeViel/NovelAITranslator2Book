# Novel AI configuration
# Profile: Docker Compose development
# Copy this file to deploy/.env and replace placeholders as needed.
# Never commit real credentials or secrets.
#
# Complete variable reference: docs/environment.md

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Supported values: development, production
ENV=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

NOVEL_LIBRARY_DIR=/app/storage/novel_library

# Supported backends: filesystem, s3
STORAGE_BACKEND=filesystem
#S3_BUCKET=your-bucket-name
#S3_REGION=auto
#S3_KEY_PREFIX=
#S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#S3_ACCESS_KEY_ID=your-application-access-key-id
#S3_SECRET_ACCESS_KEY=your-application-secret-access-key
S3_STORAGE_LIMIT_GB=9.5

# ---------------------------------------------------------------------------
# Object snapshots
# ---------------------------------------------------------------------------

BACKUP_ENABLED=false
BACKUP_S3_ENABLED=false
#BACKUP_S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#BACKUP_S3_REGION=auto
#BACKUP_S3_BUCKET=your-independent-backup-bucket
#BACKUP_S3_PREFIX=snapshots
#BACKUP_S3_ACCESS_KEY_ID=your-backup-target-access-key-id
#BACKUP_S3_SECRET_ACCESS_KEY=your-backup-target-secret-access-key
#SNAPSHOT_SOURCE_S3_ACCESS_KEY_ID=your-read-only-source-access-key-id
#SNAPSHOT_SOURCE_S3_SECRET_ACCESS_KEY=your-read-only-source-secret-access-key

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL URL format:
# postgresql+psycopg://user:password@host:5432/database
#DATABASE_URL=user:password@database-host:5432/novelai
DB_CONNECTION_MODE=direct
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_CONNECTION_BUDGET=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
DB_SSL_MODE=prefer
DB_STATEMENT_TIMEOUT_MS=120000
DB_LOCK_TIMEOUT_MS=10000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Database backup and restore verification
# ---------------------------------------------------------------------------

DATABASE_BACKUP_ENABLED=false
DATABASE_BACKUP_SCHEDULE_CRON=0 1 * * *
DATABASE_BACKUP_TIMEZONE=UTC
DATABASE_BACKUP_S3_PREFIX=database
DATABASE_BACKUP_RETENTION_DAYS=30
DATABASE_BACKUP_MIN_SUCCESSFUL_TO_KEEP=3
#DATABASE_BACKUP_ENCRYPTION_KEY=replace-with-a-dedicated-secret
DATABASE_RESTORE_VERIFICATION_ENABLED=false
DATABASE_RESTORE_VERIFICATION_SCHEDULE_CRON=0 3 1 * *
DATABASE_RESTORE_VERIFICATION_TIMEZONE=UTC
#DATABASE_RESTORE_TARGET_URL=user:password@database-host:5432/novelai_restore_verify
DATABASE_RESTORE_SSL_MODE=prefer
#DATABASE_RESTORE_PASSWORD=replace-with-a-dedicated-local-restore-password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_CORS_ORIGINS=[\"http://localhost:3000\"]
WEB_RATE_LIMITER_BACKEND=memory
WEB_REQUEST_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Session and authentication
# ---------------------------------------------------------------------------

# Generate secrets with:
# python -c "import secrets; print(secrets.token_hex(32))"
#SESSION_SECRET_KEY=replace-with-a-strong-random-secret
#OWNER_BOOTSTRAP_SECRET=replace-with-a-different-strong-random-secret
SESSION_MAX_AGE=28800
SESSION_COOKIE_SECURE=false
PUBLIC_FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------

#GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
#GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
#GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ---------------------------------------------------------------------------
# Auth email delivery
# ---------------------------------------------------------------------------

AUTH_EMAIL_DELIVERY_MODE=noop
AUTH_PASSWORD_RESET_PATH=/password/reset
AUTH_EMAIL_VERIFICATION_PATH=/email/verify
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USERNAME=your-smtp-username
#SMTP_PASSWORD=your-smtp-password
#SMTP_FROM_EMAIL=noreply@yourdomain.com
#SMTP_FROM_NAME=Dokushodo
#SMTP_STARTTLS=true
#SMTP_USE_SSL=false
#SMTP_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Translation providers
# ---------------------------------------------------------------------------

PROVIDER_DEFAULT=gemini
#PROVIDER_GEMINI_API_KEY=your-google-ai-studio-api-key
#PROVIDER_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-local-secret
PROVIDER_GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
PROVIDER_GEMINI_MODEL_FALLBACKS=["gemma-4-31b-it"]
TRANSLATION_TARGET_LANGUAGE=English

# ---------------------------------------------------------------------------
# Jobs and scheduling
# ---------------------------------------------------------------------------

JOB_WORKER_ENABLED=false
JOB_WORKER_POLL_SECONDS=3
SCHEDULED_JOB_LEASE_SECONDS=900

# ---------------------------------------------------------------------------
# Operator alerts
# ---------------------------------------------------------------------------

OPERATOR_ALERT_ENABLED=false
#OPERATOR_ALERT_EMAIL=ops@example.com
OPERATOR_ALERT_FAILURE_THRESHOLD=3
OPERATOR_ALERT_COOLDOWN_SECONDS=3600
OPERATOR_ALERT_STALE_BACKUP_HOURS=36

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------

PUBLIC_HTTP_PORT=80
#PUBLIC_HTTPS_PORT=443
#SITE_DOMAIN=localhost
