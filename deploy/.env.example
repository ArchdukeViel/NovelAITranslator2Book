# ─── Novel AI Environment Variables ───────────────────────────────────────
# Copy this file to deploy/.env and fill in your values.
#   cp deploy/.env.example deploy/.env
#
# Docker Compose reads .env from the deploy/ directory automatically.
# For a complete reference of all environment variables, see docs/environment.md.

# ─── Environment ───────────────────────────────────────────────────────────
# development or production
ENV=development
LOG_LEVEL=INFO

# ─── Session & Auth ───────────────────────────────────────────────────────
SESSION_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
OWNER_BOOTSTRAP_SECRET=change-me-to-another-random-secret
PUBLIC_FRONTEND_URL=http://localhost:3000

# ─── Provider ─────────────────────────────────────────────────────────────
PROVIDER_DEFAULT=gemini
#PROVIDER_GEMINI_API_KEY=your-google-ai-studio-api-key
# Generate a strong random encryption key:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#PROVIDER_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-local-secret

# ─── Database ─────────────────────────────────────────────────────────────
# For local PostgreSQL:
POSTGRES_USER=novelai
POSTGRES_PASSWORD=novelai
POSTGRES_DB=novelai
POSTGRES_HOST_PORT=5432
# For Supabase/managed PostgreSQL, set DATABASE_URL instead:
#DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ─────────────────────────────────────────────────────────────────
#REDIS_URL=redis://localhost:6379/0

# ─── Email (SMTP) ─────────────────────────────────────────────────────────
# Set to "smtp" to enable real email delivery, "noop" to disable.
AUTH_EMAIL_DELIVERY_MODE=noop
AUTH_PASSWORD_RESET_PATH=/password/reset
AUTH_EMAIL_VERIFICATION_PATH=/email/verify
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=Dokushodo
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=10

# ─── Google OAuth ─────────────────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# ─── Translation ──────────────────────────────────────────────────────────
TRANSLATION_TARGET_LANGUAGE=English

# ─── Web ──────────────────────────────────────────────────────────────────
WEB_CORS_ORIGINS=["http://localhost:3000"]
WEB_RATE_LIMITER_BACKEND=memory
WEB_REQUEST_TIMEOUT_SECONDS=120

# ─── Jobs ─────────────────────────────────────────────────────────────────
JOB_WORKER_ENABLED=false
JOB_WORKER_POLL_SECONDS=3

# ─── Ports (Docker Compose) ──────────────────────────────────────────────
#PUBLIC_HTTP_PORT=80
#PUBLIC_HTTPS_PORT=443
