# Production Caddyfile template for HTTPS via Let's Encrypt.
#
# Usage:
#   1. Copy this file to deploy/Caddyfile (or mount it directly).
#   2. Replace {$SITE_DOMAIN} with your actual domain, or set the
#      SITE_DOMAIN environment variable in your .env / compose env_file.
#   3. Ensure DNS A/AAAA records point to this server.
#   4. Caddy automatically provisions and renews TLS certificates.
#
# For local development, use deploy/Caddyfile instead (HTTP-only on :80).

{$SITE_DOMAIN:yourdomain.com} {
  encode zstd gzip

  # Set HTTPS headers
  header {
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  handle /api/admin/* {
    reverse_proxy backend:8000
  }

  handle /api/auth/* {
    reverse_proxy backend:8000
  }

  handle /api/novels/* {
    reverse_proxy backend:8000
  }

  handle /api/public/* {
    reverse_proxy reader:8001
  }

  handle /novels/* {
    reverse_proxy backend:8000
  }

  handle {
    reverse_proxy frontend:3000
  }
}

# For Docker Compose, this file proxies to:
# - backend:8000 for /api/*
# - frontend:3000 for everything else
