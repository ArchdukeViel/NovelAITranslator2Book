# Production deployment environment.
# Copy this file to deploy/.env and fill in production values.
# See deploy/.env.example for the full variable reference.
#
# For a complete reference of all environment variables, see docs/environment.md.

ENV=production
PUBLIC_HTTP_PORT=8080

# Required: Strong, unique session secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace_with_a_strong_random_secret

# Required: Owner bootstrap secret for seeding the single admin owner account.
OWNER_BOOTSTRAP_SECRET=replace_with_a_strong_random_secret

# Required: Public-facing URL for the frontend (used for CORS, cookies, OAuth redirects).
PUBLIC_FRONTEND_URL=https://your-domain.example.com

NOVEL_LIBRARY_DIR=/app/storage/novel_library
PROVIDER_DEFAULT=gemini
TRANSLATION_TARGET_LANGUAGE=English

# Uncomment and fill at least one real provider key for production translation.
# PROVIDER_GEMINI_API_KEY=your_gemini_key_here
# PROVIDER_OPENAI_API_KEY=your_openai_key_here

LOG_LEVEL=INFO
WEB_CORS_ORIGINS=[]
WEB_RATE_LIMITER_BACKEND=redis
WEB_REQUEST_TIMEOUT_SECONDS=120

# Required: PostgreSQL connection string.
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Strongly recommended for a public admin deployment.
# WEB_API_KEY=replace_with_a_long_random_admin_token

JOB_WORKER_ENABLED=false
JOB_WORKER_POLL_SECONDS=3
